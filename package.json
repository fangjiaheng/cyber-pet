{
  "name": "desktop-pet",
  "version": "0.1.0",
  "description": "致敬经典 QQ 宠物的桌面宠物应用",
  "main": "dist/main/index.js",
  "author": "Erase",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"npm run watch:main\" \"npm run start:electron\"",
    "dev:renderer": "vite",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "start:electron": "wait-on http://localhost:5173 && wait-on dist/main/index.js && cross-env NODE_ENV=development electron dist/main/index.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && tsc src/main/preload.ts --outDir dist/main --skipLibCheck",
    "start": "electron dist/main/index.js",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@ruffle-rs/ruffle": "^0.2.0-nightly.2026.3.6",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^20.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.desktoppet.app",
    "productName": "桌面宠物",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "icon": "build/icon.png"
    }
  }
}
